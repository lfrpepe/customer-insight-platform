# Copie este arquivo para .env e preencha com os dados reais do seu projeto Supabase.
# NUNCA commite o arquivo .env (deve estar no .gitignore).
#
# Onde encontrar: Supabase Dashboard > Project Settings > Database >
# Connection string > aba "Session pooler" (porta 5432, compatível com IPv4).

SUPABASE_DB_HOST=aws-0-sa-east-1.pooler.supabase.com
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres.xxxxxxxxxxxx
SUPABASE_DB_PASSWORD=
